<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Josephine De Maria — Graphic Designer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --green: #1a3a2a;
    --green-mid: #22493a;
    --green-light: #2d5c4a;
    --cream: #f5f0e8;
    --white: #ffffff;
    --accent: #FFE973;
    --red: #EF373E;
    --tint: #F9CCC2;
    --text-muted: rgba(245,240,232,0.55);
    --serif: 'Playfair Display', Georgia, serif;
    --sans: 'DM Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--green);
    color: var(--cream);
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 3rem;
    background: rgba(26,58,42,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(245,240,232,0.08);
  }

  .nav-logo {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--cream); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 3rem 5rem 3rem;
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .hero-title {
    font-family: var(--serif);
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 900;
    line-height: 1.0;
    color: var(--cream);
    margin-bottom: 1.5rem;
  }

  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-sub {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 380px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--accent);
    color: var(--green);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    border-radius: 0;
    transition: background 0.2s, transform 0.15s;
    align-self: flex-start;
  }

  .hero-cta:hover { background: var(--cream); transform: translateY(-2px); }

  .hero-right {
    position: relative;
    overflow: hidden;
  }

  .hero-video-wrap {
    width: 100%;
    height: 100%;
    min-height: 600px;
    position: relative;
    background: var(--green-mid);
  }

  .hero-video-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--green-light);
    color: var(--text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    gap: 1rem;
    border-left: 1px solid rgba(245,240,232,0.1);
  }

  .play-btn {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
  }

  .play-btn svg { margin-left: 4px; }

  /* REPLACE THIS with your actual video:
     <video autoplay muted loop playsinline style="width:100%;height:100%;object-fit:cover;">
       <source src="https://vimeo.com/manage/videos/1115056209/6508de05f1?fl=pl&fe=ti" type="video/mp4">
     </video>
  */

  /* ── SECTION BASE ── */
  section { padding: 6rem 3rem; }

  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .section-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }

  /* ── MARQUEE ── */
  .marquee-wrap {
    background: var(--accent);
    overflow: hidden;
    padding: 0.85rem 0;
    white-space: nowrap;
  }

  .marquee-inner {
    display: inline-block;
    animation: marquee 18s linear infinite;
  }

  .marquee-inner span {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--green);
    padding: 0 2.5rem;
  }

  .marquee-inner span::after {
    content: '✦';
    margin-left: 2.5rem;
    font-style: normal;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── FEATURED WORK ── */
  .work-section { padding: 6rem 3rem; }

  .work-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
  }

  .view-all {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: 1px solid rgba(245,240,232,0.25);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .view-all:hover { color: var(--cream); border-color: var(--cream); }

  /* Featured big card */
  .work-featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: 1.5rem;
    background: var(--green-mid);
    border: 1px solid rgba(245,240,232,0.08);
    overflow: hidden;
    transition: transform 0.3s;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .work-featured:hover { transform: translateY(-4px); }

  .work-featured-img {
    min-height: 480px;
    background: var(--green-light);
    position: relative;
    overflow: hidden;
  }

  .work-img-inner {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .work-featured:hover .work-img-inner { transform: scale(1.03); }

  .work-featured-img-placeholder {
    width: 100%;
    height: 100%;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #EF373E 0%, #FFE973 100%);
    font-family: var(--serif);
    font-size: 5rem;
    font-weight: 900;
    color: var(--green);
    opacity: 0.15;
    letter-spacing: -0.05em;
  }

  .work-featured-content {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .work-tag {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(255,233,115,0.4);
    padding: 0.3rem 0.75rem;
    margin-bottom: 1.5rem;
    align-self: flex-start;
  }

  .work-card-title {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--cream);
    margin-bottom: 1rem;
  }

  .work-card-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .work-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cream);
    text-decoration: none;
    border-bottom: 1px solid rgba(245,240,232,0.3);
    padding-bottom: 2px;
    align-self: flex-start;
    transition: gap 0.2s, border-color 0.2s;
  }

  .work-link:hover { gap: 0.85rem; border-color: var(--cream); }

  /* Work grid - smaller cards */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .work-card {
    background: var(--green-mid);
    border: 1px solid rgba(245,240,232,0.08);
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s;
    display: block;
  }

  .work-card:hover { transform: translateY(-4px); }

  .work-card-img {
    height: 220px;
    background: var(--green-light);
    overflow: hidden;
    position: relative;
  }

  /* Colour blocks as image placeholders */
  .bg-red { background: linear-gradient(135deg, #EF373E, #c0272e); }
  .bg-yellow { background: linear-gradient(135deg, #FFE973, #e8d060); }
  .bg-tint { background: linear-gradient(135deg, #F9CCC2, #e8b5aa); }
  .bg-dark { background: linear-gradient(135deg, #1a3a2a, #0d2018); }
  .bg-green { background: linear-gradient(135deg, #256A50, #1a4a38); }
  .bg-mint { background: linear-gradient(135deg, #AECCB6, #8ab89a); }

  .work-card-img-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 3rem;
    font-weight: 900;
    color: rgba(255,255,255,0.15);
    letter-spacing: -0.05em;
  }

  .work-card-body { padding: 1.5rem; }

  .work-card-body .work-tag { margin-bottom: 0.75rem; }

  .work-card-body .work-card-title {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .work-card-body .work-card-desc {
    font-size: 0.82rem;
    margin-bottom: 0;
  }

  /* ── SKILLS / EXPERTISE ── */
  .expertise-section {
    background: var(--green-mid);
    border-top: 1px solid rgba(245,240,232,0.08);
    border-bottom: 1px solid rgba(245,240,232,0.08);
  }

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .expertise-item {
    padding: 3rem;
    border-right: 1px solid rgba(245,240,232,0.08);
    transition: background 0.2s;
  }

  .expertise-item:last-child { border-right: none; }
  .expertise-item:hover { background: rgba(255,233,115,0.04); }

  .expertise-number {
    font-family: var(--serif);
    font-size: 3.5rem;
    font-weight: 900;
    color: rgba(255,233,115,0.15);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .expertise-name {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 0.75rem;
  }

  .expertise-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── ABOUT STRIP ── */
  .about-section {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6rem;
    align-items: center;
  }

  .about-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
    color: var(--cream);
  }

  .about-title em {
    font-style: italic;
    color: var(--accent);
  }

  .about-body {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .stat-item {}
  .stat-num {
    font-family: var(--serif);
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 0.25rem;
  }

  /* ── CONTACT ── */
  .contact-section {
    background: var(--accent);
    text-align: center;
    padding: 7rem 3rem;
  }

  .contact-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 900;
    color: var(--green);
    margin-bottom: 1rem;
    line-height: 1.05;
  }

  .contact-sub {
    font-size: 1rem;
    color: rgba(26,58,42,0.7);
    margin-bottom: 2.5rem;
  }

  .contact-email {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--green);
    text-decoration: none;
    border-bottom: 2px solid var(--green);
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }

  .contact-email:hover { opacity: 0.6; }

  .contact-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
  }

  .contact-links a {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(26,58,42,0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .contact-links a:hover { color: var(--green); }

  /* ── FOOTER ── */
  footer {
    background: #111f18;
    padding: 2rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(245,240,232,0.06);
  }

  .footer-copy {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .footer-right {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  /* ── ANIMATIONS ── */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { gap: 1.5rem; }

    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-left { padding: 6rem 1.5rem 3rem; }
    .hero-right { min-height: 400px; }
    .hero-video-wrap { min-height: 400px; }
    .hero-video-placeholder { min-height: 400px; }

    section { padding: 4rem 1.5rem; }
    .work-section { padding: 4rem 1.5rem; }

    .work-featured { grid-template-columns: 1fr; }
    .work-featured-img-placeholder { min-height: 280px; }
    .work-featured-img { min-height: 280px; }

    .work-grid { grid-template-columns: 1fr; }

    .expertise-grid { grid-template-columns: 1fr; }
    .expertise-item { border-right: none; border-bottom: 1px solid rgba(245,240,232,0.08); }

    .about-section { grid-template-columns: 1fr; gap: 2rem; }

    footer { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
</head>
